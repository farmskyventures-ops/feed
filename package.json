{
  "name": "farmsky",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:css": "tailwindcss -c tailwind.config.js -i frontend/tailwind.input.css -o frontend/static/tailwind.css --minify",
    "build": "npm run build:css && vite build",
    "db:seed": "node --import tsx backend/server.ts --migrate-only",
    "build:node": "npm run build:css && esbuild backend/server.ts --bundle --platform=node --format=esm --outfile=dist-node/server.js --packages=external --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "start": "node dist-node/server.js",
    "start:dev": "node --import tsx backend/server.ts",
    "db:migrate": "node --import tsx backend/server.ts --migrate-only"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "dotenv": "^16.4.7",
    "hono": "^4.12.23",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.25.2",
    "@types/pg": "^8.11.10",
    "esbuild": "^0.24.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
