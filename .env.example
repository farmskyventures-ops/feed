# =====================================================================
# Farmsky — environment configuration (Node server)
# Copy to .env and fill in. The Node server reads these on boot.
# =====================================================================

# ----- PostgreSQL database -----
# Option A: a single connection string (recommended for managed Postgres,
#           e.g. AWS RDS, Supabase, Neon). Append ?sslmode=require for SSL.
# DATABASE_URL=postgresql://farmsky:farmsky@127.0.0.1:5432/farmsky
# DATABASE_URL=postgresql://user:pass@your-host.rds.amazonaws.com:5432/farmsky?sslmode=require

# Option B: discrete variables (used only when DATABASE_URL is unset)
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=farmsky
PGPASSWORD=farmsky
PGDATABASE=farmsky
# PGPOOL_MAX=10

# ----- HTTP server -----
PORT=8080

# ----- M-Pesa Daraja (leave blank for SIMULATION mode) -----
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_ENV=sandbox
MPESA_CALLBACK_URL=

# ----- SasaPay (alternative payment provider, leave blank for SIMULATION) -----
SASAPAY_CLIENT_ID=
SASAPAY_CLIENT_SECRET=
SASAPAY_MERCHANT_CODE=
SASAPAY_ENV=sandbox
SASAPAY_CALLBACK_URL=

# ----- KCB Buni (alternative payment provider, leave blank for SIMULATION) -----
KCB_CONSUMER_KEY=
KCB_CONSUMER_SECRET=
KCB_TILL_NUMBER=
KCB_ENV=sandbox
KCB_CALLBACK_URL=

# ----- SMS OTP provider (TalkSASA by default) -----
SMS_PROVIDER=
SMS_API_URL=
SMS_API_TOKEN=
SMS_SENDER_ID=
SMS_BODY_TEMPLATE=
SMS_PHONE_FIELD=
SMS_MESSAGE_FIELD=

# ----- Email provider (export sharing — Resend by default) -----
EMAIL_PROVIDER=
EMAIL_API_URL=
EMAIL_API_TOKEN=
EMAIL_FROM=
