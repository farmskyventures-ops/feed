# =====================================================================
# Farmsky — environment configuration (Node server)
# Copy to .env and fill in. The Node server reads these on boot.
# =====================================================================

# ----- PostgreSQL database -----
# Option A: a single connection string (recommended for managed Postgres,
#           e.g. AWS RDS, Supabase, Neon). Append ?sslmode=require for SSL.
# DATABASE_URL=postgresql://farmsky:farmsky@127.0.0.1:5432/farmsky
# DATABASE_URL=postgresql://user:pass@your-host.rds.amazonaws.com:5432/farmsky?sslmode=require

# Option B: discrete variables (used only when DATABASE_URL is unset)
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=farmsky
PGPASSWORD=farmsky
PGDATABASE=farmsky
# PGPOOL_MAX=10

# ----- HTTP server -----
PORT=8080

# =====================================================================
# CENTRAL PAYMENT GATEWAY (REQUIRED for live payments)
# ---------------------------------------------------------------------
# FEED is a SATELLITE app. It does NOT hold any M-Pesa / SasaPay / Buni
# provider credentials. Instead it forwards every payment as an
# HMAC-signed request to the MAIN app (equipment.farmsky.africa), which
# owns the single merchant shortcode and executes the real transaction.
#
# Set these THREE variables on Render for live payments. You may use
# either the canonical FARMSKY_PAYMENTS_* names OR the short aliases
# (PAYMENT_*) — the server reads both.
#
#   1) Gateway URL — the MAIN app's payments API. You may set either the
#      full API path OR just the origin; the client normalizes it and
#      auto-appends /api/v1/payments when missing.
FARMSKY_PAYMENTS_GATEWAY_URL=https://equipment.farmsky.africa/api/v1/payments
#   (alias) PAYMENT_GATEWAY_URL=https://equipment.farmsky.africa/api/v1/payments
#
#   2) Client key — identifies this app to the gateway. MUST be exactly
#      "feed" (matches the app_clients row on the MAIN app). Defaults to
#      "feed" if left blank.
FARMSKY_PAYMENTS_CLIENT_KEY=feed
#   (alias) PAYMENT_CLIENT_KEY=feed
#
#   3) HMAC secret — MUST be byte-for-byte identical to the secret stored
#      in the MAIN app's app_clients.hmac_secret row for client_key='feed'.
#      Generate/rotate with: openssl rand -hex 32
FARMSKY_PAYMENTS_HMAC_SECRET=
#   (alias) PAYMENT_HMAC_SECRET=
# =====================================================================

# ----- M-Pesa Daraja — SATELLITE: leave blank (handled by the gateway) -----
# Only used by the direct-STK FALLBACK path for local/standalone dev.
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_ENV=sandbox
MPESA_CALLBACK_URL=

# ----- SasaPay — SATELLITE: leave blank (handled by the gateway) -----
SASAPAY_CLIENT_ID=
SASAPAY_CLIENT_SECRET=
SASAPAY_MERCHANT_CODE=
SASAPAY_ENV=sandbox
SASAPAY_CALLBACK_URL=

# ----- KCB Buni — SATELLITE: leave blank (handled by the gateway) -----
KCB_CONSUMER_KEY=
KCB_CONSUMER_SECRET=
KCB_TILL_NUMBER=
KCB_ENV=sandbox
KCB_CALLBACK_URL=

# ----- SMS OTP provider (TalkSASA by default) -----
SMS_PROVIDER=
SMS_API_URL=
SMS_API_TOKEN=
SMS_SENDER_ID=
SMS_BODY_TEMPLATE=
SMS_PHONE_FIELD=
SMS_MESSAGE_FIELD=

# ----- Email provider (export sharing — Resend by default) -----
EMAIL_PROVIDER=
EMAIL_API_URL=
EMAIL_API_TOKEN=
EMAIL_FROM=
